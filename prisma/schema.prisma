generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Currency {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  code      String   // VND, USDT, USD...
  name      String   // Việt Nam Đồng, Tether, US Dollar...
  symbol    String   // ₫, $, ₮...
  rateToVnd Float    @map("rate_to_vnd") // 1 for VND, 25400 for USDT...
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, code])
  @@map("currencies")
}

model Asset {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  code         String
  name         String
  type         String    // metal, crypto, stock, savings
  currency     String    @default("VND") // currency code (VND, USDT, USD...)
  icon         String
  iconBg       String    @map("icon_bg")
  interestRate    Float?    @map("interest_rate") // annual interest rate (%) - savings only
  termMonths      Int?      @map("term_months") // savings term in months - savings only
  bankName        String?   @map("bank_name") // bank name - savings only
  maturityDate    DateTime? @map("maturity_date") @db.Date // maturity date - savings only
  principalAmount Float?    @map("principal_amount") // initial deposit amount - savings only
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, code])
  @@map("assets")
}

model Transaction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  date      DateTime @db.Date
  assetType String   @map("asset_type")
  assetCode String   @map("asset_code")
  action    String
  quantity  Float
  unitPrice Float    @map("unit_price")
  currency  String   @default("VND")
  note      String?
  icon      String
  iconBg    String   @map("icon_bg")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("transactions")
}

model Price {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  code      String
  icon      String
  type      String
  price     Float
  currency  String   @default("VND") // currency the price is denominated in
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, code])
  @@map("prices")
}

model AllocationTarget {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  assetType     String   @map("asset_type")
  targetPercent Float    @map("target_percent")
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, assetType])
  @@map("allocation_targets")
}

model FinancialGoal {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  name          String
  targetAmount  Float    @map("target_amount")
  deadline      DateTime @db.Date
  linkedAssets  String[] @map("linked_assets")
  currentAmount Float?   @map("current_amount")
  icon          String   @default("🎯")
  iconBg        String   @default("rgba(59,130,246,0.2)") @map("icon_bg")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("financial_goals")
}
